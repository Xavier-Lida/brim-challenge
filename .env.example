# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Gemini (langchain-google-genai reads GOOGLE_API_KEY)
GOOGLE_API_KEY=
# Team default: gemini-3.1-flash-lite. thinking_budget is only sent for 2.5 models.
GEMINI_MODEL=gemini-3.1-flash-lite
GEMINI_THINKING=0

# Resend (emails)
RESEND_API_KEY=
RESEND_FROM=Brim <noreply@company.com>
APPROVER_EMAIL=approver@company.com
EMPLOYEE_EMAIL=employee@company.com

# App
APP_BASE_URL=http://localhost:3000
BACKEND_URL=http://127.0.0.1:8000
USE_MOCKS=false

# Mapbox (city geocoding for the purchase map)
MAPBOX_ACCESS_TOKEN=
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Brim Assistant narration rules (Markdown injected into Feature 1 NARRATE prompt)
ASSISTANT_NARRATE_RULES_PATH=prompts/assistant-narrate-rules.md
